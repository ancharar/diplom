# Секретный ключ Django (сгенерировать уникальный для продакшена)
SECRET_KEY=django-insecure-change-me-in-production

# Режим отладки (True/False)
DEBUG=True

# Разрешённые хосты (через запятую)
ALLOWED_HOSTS=localhost,127.0.0.1

# Настройки PostgreSQL
DB_NAME=scientific_pm
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB_NAME=scientific_pm_docs

# VK API
VK_APP_ID=твой_vk_app_id
VK_APP_SECRET=твой_vk_app_secret
VK_REDIRECT_URI=http://localhost:8000/api/v1/vk/callback/

# JWT
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=7

# Бэкапы
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30

# Фронтенд (для VK OAuth redirect)
FRONTEND_URL=http://localhost:5173
